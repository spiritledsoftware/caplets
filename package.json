{
  "name": "@caplets/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "build:core": "pnpm --filter @caplets/core build",
    "build:watch": "pnpm --filter caplets build:watch",
    "benchmark": "pnpm --filter @caplets/benchmarks benchmark",
    "benchmark:check": "pnpm --filter @caplets/benchmarks benchmark:check",
    "benchmark:live": "pnpm --filter @caplets/benchmarks benchmark:live",
    "benchmark:live:opencode": "pnpm --filter @caplets/benchmarks benchmark:live:opencode",
    "benchmark:live:pi": "pnpm --filter @caplets/benchmarks benchmark:live:pi",
    "changeset": "changeset",
    "dev": "pnpm --filter caplets dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "prepare": "husky",
    "release": "pnpm build && changeset publish",
    "schema:check": "pnpm --filter @caplets/core schema:check",
    "schema:generate": "pnpm --filter @caplets/core schema:generate",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "test": "pnpm -r --filter './packages/*' test",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm schema:check && pnpm test && pnpm benchmark:check && pnpm build",
    "version-packages": "changeset version && node scripts/sync-plugin-versions.mjs && oxfmt .codex-plugin/plugin.json .claude-plugin/plugin.json"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "rolldown": "^1.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,json,md,yml,yaml}": "oxfmt --check",
    "*.{js,cjs,mjs,ts}": "oxlint"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.9"
}
