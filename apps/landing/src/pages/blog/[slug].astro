---
import { render } from "astro:content";

import BlogArticle from "../../components/landing/BlogArticle.astro";
import BlogCta from "../../components/landing/BlogCta.astro";
import Footer from "../../components/landing/Footer.astro";
import Header from "../../components/landing/Header.astro";
import LandingLayout from "../../layouts/LandingLayout.astro";
import { absoluteBlogPostUrl, blogPostUrl, getSortedBlogPosts } from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getSortedBlogPosts();

  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const canonicalPath = blogPostUrl(entry.slug);
const canonicalUrl = absoluteBlogPostUrl(entry.slug);
---

<LandingLayout
  canonicalUrl={canonicalUrl}
  title={`${entry.data.title} | Caplets Blog`}
  description={entry.data.description}
  ogType="article"
  ogImage={entry.data.ogImage ?? "/icon.png"}
>
  <Header slot="header" />
  <BlogArticle title={entry.data.title} description={entry.data.description} date={entry.data.date} canonicalPath={canonicalPath}>
    <Content />
    <BlogCta />
  </BlogArticle>
  <Footer slot="footer" />
</LandingLayout>

<script>
  import "../../scripts/observability";
  import "../../scripts/header-collapse";
</script>
