---
import ArrowUpRight from "@tabler/icons/outline/arrow-up-right.svg";
---

<footer class="border-t border-border py-10">
  <div class="mx-auto flex w-[min(1180px,calc(100vw_-_32px))] flex-col gap-5 text-sm text-muted-foreground md:flex-row md:items-center md:justify-between">
    <p>Caplets gives agents capabilities, not giant tool walls.</p>
    <nav class="flex flex-wrap gap-4" aria-label="Footer links">
      <a class="inline-flex min-h-11 items-center gap-1 font-medium hover:text-foreground" href="https://docs.caplets.dev">
        Docs
        <ArrowUpRight class="size-3.5" aria-hidden="true" />
      </a>
      <a class="inline-flex min-h-11 items-center gap-1 font-medium hover:text-foreground" href="https://github.com/spiritledsoftware/caplets">
        GitHub repo
        <ArrowUpRight class="size-3.5" aria-hidden="true" />
      </a>
      <a class="inline-flex min-h-11 items-center gap-1 font-medium hover:text-foreground" href="https://www.npmjs.com/package/caplets">
        npm package
        <ArrowUpRight class="size-3.5" aria-hidden="true" />
      </a>
    </nav>
  </div>
</footer>
