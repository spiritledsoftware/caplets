{
  "tasks": {
    "clean": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@caplets/core#build": {
      "dependsOn": ["@caplets/dashboard#build", "^build"],
      "outputs": ["dist/**"]
    },
    "build:watch": {
      "persistent": true,
      "cache": false
    },
    "catalog:check": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"]
    }
  }
}
