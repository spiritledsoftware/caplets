{
  "name": "@caplets/benchmarks",
  "private": true,
  "type": "module",
  "scripts": {
    "benchmark": "tsx run-deterministic.ts",
    "benchmark:check": "tsx run-deterministic.ts --check",
    "benchmark:live": "tsx run-live.ts",
    "benchmark:live:opencode": "tsx run-live.ts --agent opencode",
    "benchmark:live:pi": "tsx run-live.ts --agent pi",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "benchmark:live:pi-eval": "tsx run-pi-eval.ts",
    "benchmark:live:pi-eval:competitors": "tsx run-pi-eval.ts --mode caplets-code-mode,caplets-direct-code-mode,caplets-progressive-code-mode,vanilla-mcp,executor-mcp"
  },
  "dependencies": {
    "@caplets/core": "workspace:*",
    "commander": "^15.0.0",
    "js-tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "caplets": "workspace:*",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
