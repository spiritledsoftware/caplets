{
  "name": "@caplets/benchmarks",
  "private": true,
  "type": "module",
  "scripts": {
    "benchmark": "tsx run-deterministic.ts",
    "benchmark:check": "tsx run-deterministic.ts --check",
    "benchmark:live": "tsx run-live.ts",
    "benchmark:live:opencode": "tsx run-live.ts --agent opencode",
    "benchmark:live:pi": "tsx run-live.ts --agent pi",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@caplets/core": "workspace:*",
    "caplets": "workspace:*",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
