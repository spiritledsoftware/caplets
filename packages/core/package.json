{
  "name": "@caplets/core",
  "version": "0.18.4",
  "description": "Core runtime library for Caplets progressive disclosure gateways.",
  "keywords": [
    "caplets",
    "gateway",
    "mcp",
    "model-context-protocol",
    "tools"
  ],
  "homepage": "https://github.com/spiritledsoftware/caplets#readme",
  "bugs": {
    "url": "https://github.com/spiritledsoftware/caplets/issues"
  },
  "license": "MIT",
  "author": "Spirit-Led Software LLC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spiritledsoftware/caplets.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./generated-tool-input-schema": {
      "types": "./dist/generated-tool-input-schema.d.ts",
      "default": "./dist/generated-tool-input-schema.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "default": "./dist/native.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && rolldown -c && tsc -p tsconfig.build.json",
    "build:watch": "pnpm run clean && rolldown -c --watch",
    "prepack": "pnpm build",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@hono/mcp": "^0.3.0",
    "@hono/node-server": "^2.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "graphql": "^16.14.0",
    "hono": "^4.12.22",
    "vfile": "^6.0.3",
    "vfile-matter": "^5.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "rolldown": "^1.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22"
  }
}
