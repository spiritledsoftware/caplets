{
  "name": "caplets",
  "version": "0.25.6",
  "description": "Progressive disclosure gateway CLI for MCP servers and native Caplets adapters.",
  "keywords": [
    "caplets",
    "gateway",
    "mcp",
    "model-context-protocol",
    "tools"
  ],
  "homepage": "https://github.com/spiritledsoftware/caplets#readme",
  "bugs": {
    "url": "https://github.com/spiritledsoftware/caplets/issues"
  },
  "license": "MIT",
  "author": "Spirit-Led Software LLC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spiritledsoftware/caplets.git",
    "directory": "packages/cli"
  },
  "bin": {
    "caplets": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && rolldown -c",
    "build:watch": "pnpm run clean && rolldown -c --watch",
    "prepack": "rm -f README.md && cp ../../README.md README.md",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@caplets/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "@typescript/native-preview": "7.0.0-dev.20260628.1",
    "rolldown": "^1.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "bun": ">=1",
    "node": ">=22"
  }
}
