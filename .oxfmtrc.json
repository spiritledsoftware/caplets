  "ignorePatterns": ["**/.brv/**", "apps/catalog/src/data/official-catalog.json"],
  "plugins": ["prettier-plugin-astro"],
  "overrides": [
    {
      "files": ["*.astro"],
      "options": {
        "parser": "astro"
      }
    }
  ]
}
